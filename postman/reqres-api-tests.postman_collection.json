    {
      "name": "https://reqres.in/api/users\n",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201 Created\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"User was created with correct name\", function () {\r",
              "    var json = pm.response.json();\r",
              "    pm.expect(json.name).to.eql(\"Keerthi Begari\");\r",
              "});\r",
              "\r",
              "pm.test(\"User was created with correct job\", function () {\r",
              "    var json = pm.response.json();\r",
              "    pm.expect(json.job).to.eql(\"QA Engineer\");\r",
              "});\r",
              "\r",
              "pm.test(\"New user has an ID\", function () {\r",
              "    var json = pm.response.json();\r",
              "    pm.expect(json.id).to.exist;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
